  <tendon>
        <fixed name="roll_r">
            <joint joint="hip_roll_r" coef="1"/>
        </fixed>
        <fixed name="pitch_r">
            <joint joint="hip_pitch_r" coef="1"/>
        </fixed>
        <fixed name="sum_r">
            <joint joint="hip_actuatorR_r" coef="0.5"/>
            <joint joint="hip_actuatorR_l" coef="0.5"/>
        </fixed>
        <fixed name="diff_r">
            <joint joint="hip_actuatorR_r" coef=".5"/>
            <joint joint="hip_actuatorR_l" coef="-.5"/>
        </fixed>

        <fixed name="roll_l">
            <joint joint="hip_roll_l" coef="1"/>
        </fixed>
        <fixed name="pitch_l">
            <joint joint="hip_pitch_l" coef="1"/>
        </fixed>
        <fixed name="sum_l">
            <joint joint="hip_actuatorL_r" coef="0.5"/>
            <joint joint="hip_actuatorL_l" coef="0.5"/>
        </fixed>
        <fixed name="diff_l">
            <joint joint="hip_actuatorL_r" coef=".5"/>
            <joint joint="hip_actuatorL_l" coef="-.5"/>
        </fixed>
    </tendon>

  <equality>
          <!-- For right differential mechanism -->
    <tendon tendon1="roll_r" tendon2="sum_r" polycoef="0 -1 0 0 0"/>
    <tendon tendon1="pitch_r" tendon2="diff_r" polycoef="0 -1 0 0 0"/>
    <!-- For left differential mechanism -->
    <tendon tendon1="roll_l" tendon2="sum_l" polycoef="0 -1 0 0 0"/>
    <tendon tendon1="pitch_l" tendon2="diff_l" polycoef="0 -1 0 0 0"/>
    <!-- <connect site1='ankle_upper_attach_l' solref="0.005 1.05" solimp="0.2 0.95 0.002 0.9 6" site2='achilles_attach_l'/> -->
    <!-- <connect site1='ankle_upper_attach_r' solref="0.005 1.05" solimp="0.2 0.95 0.002 0.9 6" site2='achilles_attach_r'/> -->
    <connect site1='ankle_upper_attach_l' site2='achilles_attach_l'/>
    <connect site1='ankle_upper_attach_r' site2='achilles_attach_r'/>
  </equality>

  <!-- <contact>
    <pair name="r_collision_floor" geom1="right_foot_collision" geom2="plane" condim="3"/>
    <pair name="l_collision_floor" geom1="left_foot_collision" geom2="plane" condim="3"/>
  </contact> -->

  <!--Sim gains for sim-dt = 0.004-->
  <actuator>
    <position class="bear" joint="hip_yaw_r"       name="hip_yaw_r_pos"/>
    <position class="bear" joint="hip_actuatorR_r" name="hip_actuatorR_r_pos"/>
    <position class="bear" joint="hip_actuatorR_l" name="hip_actuatorR_l_pos"/>
    <position class="bear" joint="knee_pitch_r"    name="knee_pitch_r_pos"/>
    <position class="bear" joint="ankle_crank_r"   name="ankle_crank_r_pos"/>

    <position class="bear" joint="hip_yaw_l"       name="hip_yaw_l_pos"/>
    <position class="bear" joint="hip_actuatorL_r" name="hip_actuatorL_r_pos"/>
    <position class="bear" joint="hip_actuatorL_l" name="hip_actuatorL_l_pos"/>
    <position class="bear" joint="knee_pitch_l"    name="knee_pitch_l_pos"/>
    <position class="bear" joint="ankle_crank_l"   name="ankle_crank_l_pos"/>

    <position name="shoulder_pitch_r"  joint="shoulder_pitch_r" kp="5" forcerange="-3 3"/>
    <position name="shoulder_roll_r"   joint="shoulder_roll_r"  kp="5" forcerange="-3 3"/>
    <position name="elbow_pitch_r"     joint="elbow_pitch_r"    kp="5" forcerange="-3 3"/>
    <position name="shoulder_pitch_l"  joint="shoulder_pitch_l" kp="5" forcerange="-3 3"/>
    <position name="shoulder_roll_l"   joint="shoulder_roll_l"  kp="5" forcerange="-3 3"/>
    <position name="elbow_pitch_l"     joint="elbow_pitch_l"    kp="5" forcerange="-3 3"/>


    <velocity class="bear-vel" joint="hip_yaw_r"       name="hip_yaw_r_vel"/>
    <velocity class="bear-vel" joint="hip_actuatorR_r" name="hip_actuatorR_r_vel"/>
    <velocity class="bear-vel" joint="hip_actuatorR_l" name="hip_actuatorR_l_vel"/>
    <velocity class="bear-vel" joint="knee_pitch_r"    name="knee_pitch_r_vel"/>
    <velocity class="bear-vel" joint="ankle_crank_r"   name="ankle_crank_r_vel"/>

    <velocity class="bear-vel" joint="hip_yaw_l"       name="hip_yaw_l_vel"/>
    <velocity class="bear-vel" joint="hip_actuatorL_r" name="hip_actuatorL_r_vel"/>
    <velocity class="bear-vel" joint="hip_actuatorL_l" name="hip_actuatorL_l_vel"/>
    <velocity class="bear-vel" joint="knee_pitch_l"    name="knee_pitch_l_vel"/>
    <velocity class="bear-vel" joint="ankle_crank_l"   name="ankle_crank_l_vel"/>

    <velocity  name="shoulder_pitch_r_vel"  joint="shoulder_pitch_r"  forcerange="-1 1" kv="0.1"/>
    <velocity  name="shoulder_roll_r_vel"   joint="shoulder_roll_r"   forcerange="-1 1" kv="0.1"/>
    <velocity  name="elbow_pitch_r_vel"     joint="elbow_pitch_r"     forcerange="-1 1" kv="0.1"/>
    <velocity  name="shoulder_pitch_l_vel"  joint="shoulder_pitch_l"  forcerange="-1 1" kv="0.1"/>
    <velocity  name="shoulder_roll_l_vel"   joint="shoulder_roll_l"   forcerange="-1 1" kv="0.1"/>
    <velocity  name="elbow_pitch_l_vel"     joint="elbow_pitch_l"     forcerange="-1 1" kv="0.1"/>
  </actuator>
  
  <sensor>
    <touch name="opto1" site="0"/>
    <touch name="opto2" site="1"/>
    <touch name="opto3" site="2"/>
    <touch name="opto4" site="3"/>
    <gyro name="base_gyro" site="base_IMU"/>
    <accelerometer name="base_accelerometer" site="base_IMU"/>
    <framexaxis name="left_foot_z" objtype="site" objname="midfoot_l"/>
    <framexaxis name="right_foot_z" objtype="site" objname="midfoot_r"/>
    <framepos name="right_foot" objtype='site' objname='midfoot_r'/>
    <framepos name="left_foot" objtype='site' objname='midfoot_l'/>
    <framelinvel name="right_foot_vel" objtype='site' objname='midfoot_r'/>
    <framelinvel name="left_foot_vel" objtype='site' objname='midfoot_l'/>
    <velocimeter name="base_velocimeter" site="base_IMU"/>
  </sensor>

</mujoco>
